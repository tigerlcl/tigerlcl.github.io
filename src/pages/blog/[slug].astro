---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={`${post.data.title} | Changlun Li`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-5 py-20 sm:px-8">
    <a href="/blog/" class="text-sm font-semibold text-zinc-600 hover:text-zinc-950 dark:text-mist dark:hover:text-white">← Notes</a>
    <p class="mt-10 text-xs font-bold uppercase tracking-[0.28em] text-zinc-500 dark:text-mist">{post.data.pubDate.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
    <h1 class="mt-4 font-serif text-5xl leading-tight tracking-[-0.05em] sm:text-6xl">{post.data.title}</h1>
    <p class="mt-5 text-lg leading-8 text-zinc-600 dark:text-mist">{post.data.description}</p>
    <div class="prose prose-zinc mt-12 max-w-none prose-headings:font-serif prose-headings:tracking-[-0.03em] prose-a:text-zinc-950 prose-pre:border prose-pre:border-line prose-pre:bg-ink dark:prose-invert dark:prose-a:text-white">
      <Content />
    </div>
  </article>
</BaseLayout>
