---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Notes | Changlun Li" description="Technical notes on LLMs, AI systems, data transformation, and AI for finance.">
  <section class="mx-auto max-w-5xl px-5 py-20 sm:px-8">
    <p class="mb-3 text-xs font-bold uppercase tracking-[0.34em] text-zinc-500 dark:text-mist">Blog / Notes</p>
    <h1 class="font-serif text-6xl tracking-[-0.06em]">Technical notes.</h1>
    <div class="mt-12 grid gap-4">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="publication-card block hover:-translate-y-1">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500 dark:text-mist">{post.data.pubDate.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
          <h2 class="mt-3 font-serif text-3xl tracking-[-0.04em]">{post.data.title}</h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 dark:text-mist">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
