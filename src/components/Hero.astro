---
import IconLink from './IconLink';
import { MapPin } from 'lucide-react';
import selfie from '../../assets/img/selfie.jpg';
---
<section class="mx-auto grid max-w-7xl items-end gap-12 px-5 py-20 sm:px-8 lg:grid-cols-[1fr_360px] lg:py-28">
  <div>
    <p class="aurora-kicker mb-6 text-xs font-bold uppercase tracking-[0.36em]">AI + Data Research · FinTech Entrepreneurship</p>
    <h1 class="max-w-5xl font-serif text-6xl leading-[0.92] tracking-[-0.06em] text-zinc-950 dark:text-white sm:text-7xl lg:text-8xl">
      I build <span class="aurora-text">trustworthy AI</span> systems for data and decision intelligence.
    </h1>
    <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-600 dark:text-mist">
      Ph.D. Candidate at HKUST(GZ), optimizing Large Language Models for data transformation and financial markets.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-3">
      <span class="inline-flex h-11 items-center gap-2 rounded-full border border-zinc-300 bg-white/60 px-4 text-sm font-medium text-zinc-700 dark:border-line dark:bg-white/[0.03] dark:text-mist">
        <MapPin className="h-4 w-4" strokeWidth={1.7} />
        Guangzhou & HongKong
      </span>
      <IconLink href="https://github.com/tigerlcl" label="GitHub" icon="github" />
      <IconLink href="https://scholar.google.com/citations?user=qzEce6IAAAAJ&hl=en" label="Google Scholar" icon="scholar" />
      <IconLink href="https://www.linkedin.com/in/changlunli0718/" label="LinkedIn" icon="linkedin" />
      <IconLink href="mailto:tigerlicuhk@gmail.com" label="tigerlicuhk@gmail.com" icon="email" />
    </div>
  </div>
  <figure class="relative mx-auto w-full max-w-[240px] overflow-hidden rounded-[2rem] border border-zinc-200 bg-white/70 p-3 shadow-glow dark:border-line dark:bg-white/[0.03] lg:mx-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.75),transparent_45%)] dark:bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.12),transparent_45%)]"></div>
    <img
      src={selfie.src}
      alt="Changlun Li portrait"
      class="relative aspect-[4/5] w-full rounded-[1.45rem] object-cover grayscale-[15%]"
      loading="eager"
    />
  </figure>
</section>
