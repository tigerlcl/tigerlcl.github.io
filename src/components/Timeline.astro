---
import SectionHeading from './SectionHeading.astro';

const items = [
  { period: '2025 - Present', title: 'Founder & CEO', org: 'Paradoox AI', detail: 'Building trustworthy AI products for fund investment.' },
  { period: '2024 - Present', title: 'Ph.D. Candidate', org: 'HKUST(GZ), Data Science and Analytics Thrust', detail: 'Applied AI, LLM data systems, and trustworthy investment intelligence.' },
  { period: '2020 - 2024', title: 'Data Scientist', org: 'Measurable AI', detail: 'Derived consumer insights from transactional data across emerging markets.' },
  { period: '2016 - 2020', title: 'B.Eng. Information Engineering', org: 'The Chinese University of Hong Kong', detail: 'Minor in Computer Science.' },
];
---
<section id="experience" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <SectionHeading eyebrow="Experience" title="Research and engineering trajectory." />
  <div class="relative border-l border-zinc-200 pl-6 dark:border-line">
    {items.map((item) => (
      <article class="relative pb-10 last:pb-0">
        <span class="absolute -left-[31px] top-1 h-3 w-3 rounded-full border border-zinc-950 bg-zinc-50 dark:border-white dark:bg-ink"></span>
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500 dark:text-mist">{item.period}</p>
        <h3 class="mt-2 font-serif text-2xl tracking-[-0.03em]">{item.title}</h3>
        <p class="mt-1 text-sm font-semibold text-zinc-700 dark:text-zinc-200">{item.org}</p>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 dark:text-mist">{item.detail}</p>
      </article>
    ))}
  </div>
</section>
