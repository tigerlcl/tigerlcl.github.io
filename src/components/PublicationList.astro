---
import type { CollectionEntry } from 'astro:content';
import IconLink from './IconLink';

interface Props {
  publications: CollectionEntry<'publications'>[];
}

const { publications } = Astro.props;
const categories = ['All', 'AI / LLMs', 'AI for Finance'];
---
<section id="publications" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mb-8 flex flex-col justify-between gap-5 md:flex-row md:items-end">
    <div>
      <p class="aurora-kicker mb-3 text-xs font-bold uppercase tracking-[0.34em]">Research</p>
      <h2 class="aurora-heading font-serif text-4xl tracking-[-0.04em] sm:text-5xl">Publications</h2>
    </div>
    <div class="flex flex-wrap gap-2" data-publication-filters>
      {categories.map((category) => (
        <button class="filter-pill" data-filter={category} aria-pressed={category === 'All'}>{category}</button>
      ))}
    </div>
  </div>
  <div class="space-y-4" data-publication-list>
    {publications.map(({ data }) => (
      <article class="publication-card" data-category={data.category}>
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="mb-3 flex flex-wrap items-center gap-2">
              <span class="rounded-full border border-zinc-200 px-3 py-1 text-xs uppercase tracking-[0.18em] text-zinc-500 dark:border-line dark:text-mist">{data.venueShort}</span>
              <span class="rounded-full bg-zinc-950 px-3 py-1 text-xs font-semibold text-white dark:bg-white dark:text-ink">{data.year}</span>
              <span class="rounded-full border border-zinc-200 px-3 py-1 text-xs text-zinc-500 dark:border-line dark:text-mist">{data.category}</span>
            </div>
            <h3 class="font-serif text-2xl leading-tight tracking-[-0.03em]">{data.title}</h3>
            <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-mist">
              {data.authors.map((author, index) => (
                <>
                  {author === data.myName ? <strong class="font-semibold text-zinc-950 dark:text-white">{author}</strong> : author}{index < data.authors.length - 1 ? ', ' : ''}
                </>
              ))}
            </p>
            <p class="mt-2 text-sm italic text-zinc-500 dark:text-mist">{data.venue}</p>
          </div>
          <div class="flex shrink-0 gap-2">
            {data.links.pdf && <IconLink href={data.links.pdf} label="PDF" icon="paper" />}
            {data.links.code && <IconLink href={data.links.code} label="Code" icon="code" />}
            {data.links.page && <IconLink href={data.links.page} label="Project page" icon="external" />}
          </div>
        </div>
        <details class="mt-5 group">
          <summary class="cursor-pointer text-sm font-semibold text-zinc-700 transition hover:text-zinc-950 dark:text-mist dark:hover:text-white">Abstract</summary>
          <p class="mt-3 max-w-4xl text-sm leading-7 text-zinc-600 dark:text-mist">{data.abstract}</p>
          {data.links.bibtex && <pre class="mt-4 overflow-x-auto rounded-2xl border border-zinc-200 bg-zinc-100 p-4 text-xs text-zinc-700 dark:border-line dark:bg-black/30 dark:text-zinc-300"><code>{data.links.bibtex}</code></pre>}
        </details>
      </article>
    ))}
  </div>
</section>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-publication-filters] button');
  const cards = document.querySelectorAll<HTMLElement>('[data-publication-list] [data-category]');

  filters.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.dataset.filter;
      filters.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
      cards.forEach((card) => {
        card.hidden = filter !== 'All' && card.dataset.category !== filter;
      });
    });
  });
</script>
